{
  "id": "kids",
  "name": "SoLoKodi Kids",
  "version": "1.3.1",
  "description": "Every official kids source pre-loaded in the home menu, fun theme, Real-Debrid kids streaming, and one-tap shortcuts.",
  "tagline": "Safe, colorful, kid-first Kodi.",
  "requires_debrid": false,
  "card_image": "kids.png",
  "website": "https://solokodi.sololink.cloud",
  "manifest_url": "https://solokodi.sololink.cloud/builds/kids/manifest.json",
  "repo_url": "https://solokodi.sololink.cloud/repo/addons.xml",
  "repository_id": "repository.solokodi",
  "skin": {
    "default_id": "skin.bello.10",
    "id": "skin.bello.10",
    "colors": [
      ["lookandfeel.skincolors", "FFFF7043"]
    ],
    "options": [
      {
        "id": "skin.bello.10",
        "label": "Bello",
        "official": true,
        "dependencies": ["script.skinshortcuts"]
      },
      {
        "id": "skin.nimbus",
        "label": "Nimbus",
        "official": false,
        "repository_id": "repository.ivarbrandt",
        "repository_name": "ivarbrandt",
        "repository_url": "https://ivarbrandt.github.io/",
        "repository_zip": "repository.ivarbrandt-1.0.3.zip",
        "dependencies": ["script.nimbus.helper"]
      }
    ]
  },
  "content_addons": [
    {"id": "plugin.video.pbskids", "label": "PBS Kids", "favourite": "PBS Kids", "menu_group": "tvshows"},
    {"id": "plugin.video.tvokids", "label": "TV Ontario Kids", "favourite": "TVO Kids", "menu_group": "tvshows"},
    {"id": "plugin.video.youtube", "label": "YouTube", "favourite": "YouTube", "menu_group": "videos"},
    {"id": "plugin.video.plutotv", "label": "Pluto TV", "favourite": "Pluto TV", "menu_group": "livetv"},
    {"id": "plugin.video.nasa", "label": "NASA", "favourite": "NASA Space", "menu_group": "videos"},
    {"id": "plugin.video.esa", "label": "ESA", "favourite": "ESA Space", "menu_group": "videos"},
    {"id": "plugin.video.iplayerwww", "label": "BBC iPlayer", "favourite": "CBeebies and CBBC", "menu_group": "tvshows"},
    {"id": "plugin.video.wdrmaus", "label": "WDR Maus", "favourite": "Die Maus", "menu_group": "tvshows"},
    {"id": "plugin.video.zdftivi", "label": "ZDF Tivi", "favourite": "ZDF Tivi", "menu_group": "tvshows"}
  ],
  "solokodi_addons": [
    {"id": "plugin.video.solokodi.kidsrd", "label": "SoLoKodi Kids Real-Debrid", "favourite": "Kids Real-Debrid", "menu_group": "movies"}
  ],
  "setup_favourite": "SoLoKodi Kids Setup",
  "wizard_steps": [
    {"id": "content_addons", "label": "Install kids sources", "required": true},
    {"id": "solokodi_addons", "label": "Install SoLoKodi add-ons", "required": true},
    {"id": "theme", "label": "Choose kids theme", "required": true},
    {"id": "favourites", "label": "Create shortcuts and home menu", "required": true},
    {"id": "realdebrid", "label": "Connect Real-Debrid", "required": false},
    {"id": "tmdb", "label": "Add TMDb API key", "required": false}
  ]
}
