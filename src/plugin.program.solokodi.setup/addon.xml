<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.solokodi.setup" name="SoLoKodi Setup" version="0.4.0" provider-name="SoLoVision">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.service" library="service.py" start="login"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">Guided setup wizard and update manager for SoLoKodi builds.</summary>
    <description lang="en_US">Sets up SoLoKodi Kids or SoLoTV (Diggz Xenon). Installs sources, themes, Diggz repository, shortcuts, Real-Debrid, and checks for build updates from the hosted manifest.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
