<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.program.solokodi.setup" name="SoLoKodi Setup" version="0.4.1" provider-name="SoLoVision">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.service" library="service.py" start="login"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">Guided setup wizard and update manager for SoLoKodi builds.</summary>
    <description lang="en_US">Sets up SoLoKodi Kids or SoLoTV. SoLoTV uses the SoLoTV Repository and Build Wizard (Xenon-based catalog). Installs shortcuts, Real-Debrid, and checks for build updates.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
<addon id="plugin.video.solokodi.kidsrd" name="SoLoKodi Kids Real-Debrid" version="0.2.3" provider-name="SoLoVision">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">Kids movies and shows through Real-Debrid.</summary>
    <description lang="en_US">Browse kids and family content with TMDb, play from your Real-Debrid library, and stream cached titles when available. Uses Real-Debrid authorization from SoLoKodi Kids Setup. v0.2.3 improves modern kids TV discovery and torrent matching.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
<addon id="repository.solokodi" name="SoLoKodi Repository" version="0.5.0" provider-name="SoLoVision">
  <extension point="xbmc.addon.repository" name="SoLoKodi Repository">
    <dir>
      <info compressed="false">https://solokodi.sololink.cloud/repo/addons.xml</info>
      <checksum>https://solokodi.sololink.cloud/repo/addons.xml.md5</checksum>
      <datadir zip="true">https://solokodi.sololink.cloud/repo/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">SoLoKodi builds — Kids, SoLoTV, and more.</summary>
    <description lang="en_US">The SoLoKodi repository ships setup wizards, update managers, and build-specific add-ons. Install once, pick Kids or SoLoTV, and use the wizard to stay current.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
<addon id="repository.solotv" name="SoLoTV Repository" version="1.0.0" provider-name="SoLoVision">
  <extension point="xbmc.addon.repository" name="SoLoTV Repository">
    <dir>
      <info compressed="false">https://solokodi.sololink.cloud/solotv/repo/addons.xml</info>
      <checksum>https://solokodi.sololink.cloud/solotv/repo/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/nebulous42069/Omega/main/omega/zips/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">SoLoTV streaming build repository.</summary>
    <description lang="en_US">Movies, TV, live channels, and Real-Debrid addons for the SoLoTV Kodi build. Maintained by SoLoVision.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud/solotv/</website>
  </extension>
</addon>
</addons>
