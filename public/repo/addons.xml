<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.program.solokodi.setup" name="SoLoKodi Kids Setup" version="0.3.4" provider-name="SoLoVision">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.service" library="service.py" start="login"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">Guided setup wizard and update manager for the SoLoKodi Kids build.</summary>
    <description lang="en_US">Walks through kids source installation, theme setup, shortcuts, Real-Debrid, and TMDb configuration. Checks for build updates and keeps SoLoKodi add-ons in sync with the hosted manifest.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
<addon id="plugin.video.solokodi.kidsrd" name="SoLoKodi Kids Real-Debrid" version="0.1.1" provider-name="SoLoVision">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">Kids movies and shows through Real-Debrid.</summary>
    <description lang="en_US">Browse kids and family content with TMDb, play from your Real-Debrid library, and stream cached titles when available. Uses Real-Debrid authorization from SoLoKodi Kids Setup.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
<addon id="repository.solokodi" name="SoLoKodi Kids Repository" version="0.4.4" provider-name="SoLoVision">
  <extension point="xbmc.addon.repository" name="SoLoKodi Kids Repository">
    <dir>
      <info compressed="false">https://solokodi.sololink.cloud/repo/addons.xml</info>
      <checksum>https://solokodi.sololink.cloud/repo/addons.xml.md5</checksum>
      <datadir zip="true">https://solokodi.sololink.cloud/repo/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">SoLoKodi Kids build — fun Kodi setup for children.</summary>
    <description lang="en_US">The SoLoKodi Kids repository ships a setup wizard, update manager, and kids streaming add-ons. Install once, then use the wizard to stay current.</description>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://solokodi.sololink.cloud</website>
  </extension>
</addon>
</addons>
